{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/forms/**",
              "components/motion/**",
              "components/product/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Unbounded|Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Unbounded, Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:q|a|key|ref|className|style|children)$/]",
        "message": "<AccordionItem> doesn't accept that prop. Declared props: q, a."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|live|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, live."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|as|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, as, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|index|hover|accent|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, index, hover, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|index|rule|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, index, rule."
      },
      {
        "selector": "JSXOpeningElement[name.name='Marquee'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|separator|reverse|duration|key|ref|className|style|children)$/]",
        "message": "<Marquee> doesn't accept that prop. Declared props: items, separator, reverse, duration."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeonField'] > JSXAttribute > JSXIdentifier[name!=/^(?:grid|grain|vignette|key|ref|className|style|children)$/]",
        "message": "<NeonField> doesn't accept that prop. Declared props: grid, grain, vignette."
      },
      {
        "selector": "JSXOpeningElement[name.name='Reveal'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|variant|index|once|threshold|key|ref|className|style|children)$/]",
        "message": "<Reveal> doesn't accept that prop. Declared props: children, as, variant, index, once, threshold."
      },
      {
        "selector": "JSXOpeningElement[name.name='Reveal'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:up|left|right|scale)$/]",
        "message": "<Reveal> variant must be one of 'up' | 'left' | 'right' | 'scale'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|kicker|title|lead|wide|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: index, kicker, title, lead, wide."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|price|tag|href|key|ref|className|style|children)$/]",
        "message": "<ServiceCard> doesn't accept that prop. Declared props: title, description, price, tag, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|mark|label|key|ref|className|style|children)$/]",
        "message": "<StatBlock> doesn't accept that prop. Declared props: value, mark, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, variant, dot."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|solid|accent)$/]",
        "message": "<Tag> variant must be one of 'default' | 'solid' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|description|image|alt|live|href|tags|key|ref|className|style|children)$/]",
        "message": "<WorkCard> doesn't accept that prop. Declared props: name, kind, description, image, alt, live, href, tags."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
